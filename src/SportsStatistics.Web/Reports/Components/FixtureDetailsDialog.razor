@implements IDialogContentComponent<List<PlayerFixtureStatisticsResponse>>

@* Header *@
<FluentDialogHeader ShowDismiss="true">
    <FluentStack VerticalAlignment="VerticalAlignment.Center">
        <FluentLabel Typo="Typography.PaneHeader">
            @Dialog.Instance.Parameters.Title
        </FluentLabel>
    </FluentStack>
</FluentDialogHeader>

@* Body *@
<FluentDialogBody>
    <FluentDataGrid Items="@Content.AsQueryable()"
                    ResizableColumns="true"
                    Style="width: 100%;">
        <PropertyColumn Property="@(p => p.SquadNumber)" Title="#" Sortable="true" />
        <PropertyColumn Property="@(p => p.PlayerName)" Title="Player" Sortable="true" />
        <PropertyColumn Property="@(p => p.Position)" Title="Pos" Sortable="true" />
        <TemplateColumn Title="Role">
            @(context.WasStarter ? "Starter" : "Sub")
        </TemplateColumn>
        <PropertyColumn Property="@(p => p.GoalCount)" Title="G" Sortable="true" />
        <PropertyColumn Property="@(p => p.GoalAssistCount)" Title="A" Sortable="true" />
        <PropertyColumn Property="@(p => p.OwnGoalCount)" Title="A" Sortable="true" />
        <PropertyColumn Property="@(p => p.PassSuccessCount)" Title="PS" Sortable="true" />
        <PropertyColumn Property="@(p => p.PassFailureCount)" Title="PF" Sortable="true" />
        <PropertyColumn Property="@(p => p.ShotOnTargetCount)" Title="SOT" Sortable="true" />
        <PropertyColumn Property="@(p => p.ShotOffTargetCount)" Title="SOFF" Sortable="true" />
        <PropertyColumn Property="@(p => p.TackleCount)" Title="Tkl" Sortable="true" />
        <PropertyColumn Property="@(p => p.FoulWonCount)" Title="FW" Sortable="true" />
        <PropertyColumn Property="@(p => p.FoulConcededCount)" Title="FC" Sortable="true" />
        <PropertyColumn Property="@(p => p.YellowCardCount)" Title="YC" Sortable="true" />
        <PropertyColumn Property="@(p => p.RedCardCount)" Title="RC" Sortable="true" />
        <PropertyColumn Property="@(p => p.SaveCount)" Title="Svs" Sortable="true" />
    </FluentDataGrid>
</FluentDialogBody>


@* Footer *@
<FluentDialogFooter>
    <FluentButton Appearance="Appearance.Accent" OnClick="@CloseAsync">Close</FluentButton>
</FluentDialogFooter>

@code {
    [Parameter]
    public List<PlayerFixtureStatisticsResponse> Content { get; set; } = default!;

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    private async Task CloseAsync()
    {
        await Dialog.CloseAsync();
    }
}
<FluentCard Style="padding: 1rem;">
    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold" Style="margin-bottom: 1rem;">
        Player Statistics - Season Summary
    </FluentLabel>

    <FluentDataGrid Items="@PlayerSeasonStatistics"
                    ResizableColumns="true"
                    RowSize="DataGridRowSize.Medium">
        <PropertyColumn Property="@(p => p.SquadNumber)" Title="#" Sortable="true" />
        <PropertyColumn Property="@(p => p.PlayerName)" Title="Player" Sortable="true" />
        <PropertyColumn Property="@(p => p.Position)" Title="Position" Sortable="true" />
        <PropertyColumn Property="@(p => p.GamesPlayed)" Title="GP" Sortable="true" />
        <PropertyColumn Property="@(p => p.GoalCount)" Title="G" Sortable="true" IsDefaultSortColumn />
        <PropertyColumn Property="@(p => p.GoalAssistCount)" Title="A" Sortable="true" />
        <PropertyColumn Property="@(p => p.PassSuccessCount)" Title="PS" Sortable="true" />
        <PropertyColumn Property="@(p => p.PassFailureCount)" Title="PF" Sortable="true" />
        <PropertyColumn Property="@(p => p.ShotOnTargetCount)" Title="SOT" Sortable="true" />
        <PropertyColumn Property="@(p => p.ShotOffTargetCount)" Title="SOFF" Sortable="true" />
        <PropertyColumn Property="@(p => p.TackleCount)" Title="Tkl" Sortable="true" />
        <PropertyColumn Property="@(p => p.FoulWonCount)" Title="FW" Sortable="true" />
        <PropertyColumn Property="@(p => p.FoulConcededCount)" Title="FC" Sortable="true" />
        <PropertyColumn Property="@(p => p.YellowCardCount)" Title="YC" Sortable="true" />
        <PropertyColumn Property="@(p => p.RedCardCount)" Title="RC" Sortable="true" />
        <TemplateColumn Align="Align.End">
            <FluentButton Appearance="Appearance.Accent"
                          IconEnd="@(new Icons.Regular.Size20.ChartPerson())"
                          OnClick="@(() => PlayerSeasonStatisticsSelected(context))" />
        </TemplateColumn>
    </FluentDataGrid>
</FluentCard>

@code {
    [Parameter]
    public IQueryable<PlayerSeasonStatisticsDto>? PlayerSeasonStatistics { get; set; }

    [Parameter]
    public EventCallback<PlayerSeasonStatisticsDto> OnPlayerSeasonStatisticsSelected { get; set; }

    private async Task PlayerSeasonStatisticsSelected(PlayerSeasonStatisticsDto player)
    {
        await OnPlayerSeasonStatisticsSelected.InvokeAsync(player);
    }
}

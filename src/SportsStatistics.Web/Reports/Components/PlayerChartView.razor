@using System.Linq.Expressions
@if (PlayerStatistics is not null)
{
    <FluentCard Style="padding: 1rem;">
        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold" Style="margin-bottom: 1rem;">
            @PlayerStatistics.PlayerName (@PlayerStatistics.Position.Name) - Statistics Breakdown
        </FluentLabel>

        <FluentGrid>
            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold" Color="Color.Success">
                        @PlayerStatistics.GoalCount.Value
                    </FluentLabel>
                    <FluentLabel>Goals</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold" Color="Color.Success">
                        @PlayerStatistics.GoalAssistCount.Value
                    </FluentLabel>
                    <FluentLabel>Assists</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold" Color="Color.Info">
                        @PlayerStatistics.ShotOnTargetCount.Value
                    </FluentLabel>
                    <FluentLabel>Shots on Target</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold">
                        @PlayerStatistics.ShotOffTargetCount.Value
                    </FluentLabel>
                    <FluentLabel>Shots off Target</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold" Color="Color.Success">
                        @PlayerStatistics.PassSuccessCount.Value
                    </FluentLabel>
                    <FluentLabel>Passes (Success)</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold">
                        @PlayerStatistics.PassFailureCount.Value
                    </FluentLabel>
                    <FluentLabel>Passes (Failed)</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold">
                        @PlayerStatistics.TackleCount.Value
                    </FluentLabel>
                    <FluentLabel>Tackles</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold">
                        @PlayerStatistics.FoulWonCount.Value
                    </FluentLabel>
                    <FluentLabel>Fouls Won</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold">
                        @PlayerStatistics.FoulConcededCount.Value
                    </FluentLabel>
                    <FluentLabel>Fouls Conceded</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold" Color="Color.Warning">
                        @PlayerStatistics.YellowCardCount.Value
                    </FluentLabel>
                    <FluentLabel>Yellow Cards</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold" Color="Color.Error">
                        @PlayerStatistics.RedCardCount.Value
                    </FluentLabel>
                    <FluentLabel>Red Cards</FluentLabel>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Style="text-align: center; padding: 1rem;">
                    <FluentLabel Weight="FontWeight.Bold">
                        @PlayerStatistics.SaveCount.Value
                    </FluentLabel>
                    <FluentLabel>Saves</FluentLabel>
                </FluentCard>
            </FluentGridItem>
        </FluentGrid>

        @* Bar Chart for Attack & Defense Stats *@
        <div style="margin-top: 2rem;">
            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="margin-bottom: 0.5rem;">
                Attack Statistics
            </FluentLabel>
            <FluentProgress
                Value="@((int)PlayerStatistics.GoalCount.Percentage)" 
                Max="100" 
                Color="Color.Success"
                Style="margin-bottom: 0.5rem;" />
            <FluentLabel>Goals (@PlayerStatistics.GoalCount.Value)</FluentLabel>
                
            <FluentProgress
                Value="@((int)PlayerStatistics.ShotOnTargetCount.Percentage)" 
                Max="100" 
                Color="Color.Info"
                Style="margin-top: 1rem; margin-bottom: 0.5rem;" />
            <FluentLabel>Shots on Target (@PlayerStatistics.ShotOnTargetCount.Value)</FluentLabel>
        </div>

        <div style="margin-top: 2rem;">
            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="margin-bottom: 0.5rem;">
                Passing Statistics
            </FluentLabel>
            <FluentProgress
                Value="@((int)PlayerStatistics.PassSuccessCount.Percentage)" 
                Max="100" 
                Color="Color.Success"
                Style="margin-bottom: 0.5rem;" />
            <FluentLabel>Successful Passes (@PlayerStatistics.PassSuccessCount.Value)</FluentLabel>
                
            <FluentProgress
                Value="@((int)PlayerStatistics.PassFailureCount.Percentage)" 
                Max="100" 
                Color="Color.Neutral"
                Style="margin-top: 1rem; margin-bottom: 0.5rem;" />
            <FluentLabel>Failed Passes (@PlayerStatistics.PassFailureCount.Value)</FluentLabel>
        </div>

        <div style="margin-top: 2rem;">
            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="margin-bottom: 0.5rem;">
                Discipline
            </FluentLabel>
            <FluentProgress
                Id="PlayerStatistics.YellowCardCount.Percentage"
                Value="@((int)PlayerStatistics.YellowCardCount.Percentage)" 
                Max="100" 
                Color="Color.Warning"
                Stroke="ProgressStroke.Large"
                Style="margin-bottom: 0.5rem;" />
            <FluentTooltip 
                Anchor="PlayerStatistics.YellowCardCount.Percentage" 
                Position="TooltipPosition.Top">
                @PlayerStatistics.YellowCardCount.Percentage
            </FluentTooltip>
            <FluentLabel>Yellow Cards (@PlayerStatistics.YellowCardCount.Value)</FluentLabel>
            <FluentProgress
                Value="@((int)PlayerStatistics.RedCardCount.Percentage)"
                Max="100" 
                Color="Color.Error"
                Style="margin-top: 1rem; margin-bottom: 0.5rem;" />
            <FluentLabel>Red Cards (@PlayerStatistics.RedCardCount.Value)</FluentLabel>
        </div>
    </FluentCard>
    }

@code {
    [Parameter]
    public PlayerSeasonStatisticsDto? PlayerStatistics { get; set; }
}

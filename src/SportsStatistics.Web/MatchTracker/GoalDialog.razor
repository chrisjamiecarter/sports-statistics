@implements IDialogContentComponent<GoalDialogData>

@* <FluentDialog Visible="@IsOpen" Title="@DialogTitle"> *@

<EditForm Model="@Input" OnValidSubmit="ConfirmAsync" FormName="player-form" style="width: 100%">
    <FluentValidator />
        
    @* Header *@
    <FluentDialogHeader ShowDismiss="true">
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentLabel Typo="Typography.PaneHeader">
                @Dialog.Instance.Parameters.Title
            </FluentLabel>
        </FluentStack>
    </FluentDialogHeader>

    @* Body *@
    <FluentDialogBody>
        <div class="full-width">
            <FluentCheckbox Name="Input.IsOwnGoal" @bind-Value="Input.IsOwnGoal" Placeholder="Is Own Goal" Label="Own Goal?" Style="width: 100%" />
            <FluentValidationMessage For="() => Input.IsOwnGoal" class="text-danger" />
        </div>

        <div class="full-width">
            <FluentSelect Id="GoalScorerSelect"
                          Name="Input.GoalScorer"
                          TOption=PlayerOptionDto
                          Label="Goal Scorer"
                          Items="Content.ScorerOptions"
                          Width="100%"
                          Placeholder="Select a player..."
                          OptionText="(p => p.Name)"
                          @bind-SelectedOption="Input.GoalScorer"
                          Disabled="!ScorerRequired"
                          Required="ScorerRequired"/>
            <FluentValidationMessage For="() => Input.GoalScorer" class="text-danger" />
        </div>

        <div class="full-width">
            <FluentSelect Id="AssisterSelect"
                          Name="Input.Assister"
                          TOption=PlayerOptionDto
                          Label="Assister"
                          Items="Content.AssisterOptions"
                          Width="100%"
                          Placeholder="Select a player..."
                          OptionText="(p => p.Name)"
                          @bind-SelectedOption="Input.Assister"
                          Disabled="!AssisterRequired"
                          Required="AssisterRequired"/>
            <FluentValidationMessage For="() => Input.Assister" class="text-danger" />
        </div>
    </FluentDialogBody>

    @* Footer *@
    <FluentDialogFooter>
        <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Style="width: 100%">
            Confirm
        </FluentButton>
        <FluentButton Type="ButtonType.Button" Appearance="Appearance.Stealth" Style="width: 100%" OnClick="CancelAsync">
            Cancel
        </FluentButton>
    </FluentDialogFooter>


@*         <FluentStack Orientation="Orientation.Vertical">
            <FluentStack Orientation="Orientation.Horizontal">
                <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Style="width: 100%">
                    Confirm
                </FluentButton>
                <FluentButton Type="ButtonType.Button" Appearance="Appearance.Stealth" Style="width: 100%" OnClick="CancelGoal">
                    Cancel
                </FluentButton>
            </FluentStack>
        </FluentStack> *@

    </EditForm>

@* </FluentDialog> *@


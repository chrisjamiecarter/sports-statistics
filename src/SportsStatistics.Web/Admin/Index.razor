@page "/admin"
@using SportsStatistics.Application.Abstractions.Messaging
@using SportsStatistics.Web.Abstractions.Messaging

<PageTitle>Admin</PageTitle>

<FluentCard>

    <FluentLabel>Admin Dashboard</FluentLabel>

    <FluentDivider />

    <FluentStack Wrap="@true">
        <FluentCard onclick="@(() => Navigation.NavigateTo(Routes.Admin.Club))">
            <FluentIcon Value="@(new Icons.Regular.Size48.People())" />
            <FluentLabel Weight="FontWeight.Bold">Club Management</FluentLabel>
            <FluentLabel>Manage club details</FluentLabel>
            <FluentButton Appearance="Appearance.Accent">Manage Club</FluentButton>
        </FluentCard>

        <FluentCard onclick="@(() => Navigation.NavigateTo(Routes.Admin.Players))">
            <FluentLabel Weight="FontWeight.Bold">Players Management</FluentLabel>
            <FluentLabel>Manage players, positions, and squad details</FluentLabel>
            <FluentButton Appearance="Appearance.Accent">Manage Players</FluentButton>
        </FluentCard>

        <FluentCard onclick="@(() => Navigation.NavigateTo(Routes.Admin.Fixtures))">
            <FluentLabel Weight="FontWeight.Bold">Fixtures Management</FluentLabel>
            <FluentLabel>Manage fixtures, results, and match data.</FluentLabel>
            <FluentButton Appearance="Appearance.Accent">Manage Fixtures</FluentButton>
        </FluentCard>
    </FluentStack>

</FluentCard>

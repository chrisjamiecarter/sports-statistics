@page "/admin"
@using SportsStatistics.Application.Abstractions.Messaging
@using SportsStatistics.Web.Abstractions.Messaging

<PageTitle>Admin</PageTitle>

<FluentStack Orientation="Orientation.Vertical">
    <FluentGrid Style="width: 100%;">
        <FluentGridItem xs="12" sm="12" md="12" lg="4">
            <FluentCard Style="cursor: pointer; height: 100%;" @onclick="@(() => Navigation.NavigateTo(Routes.Admin.Club))">
                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Start">
                    <FluentIcon Value="@(new Icons.Regular.Size32.Building())" Color="Color.Accent" />
                    <FluentLabel Weight="FontWeight.Bold" Typo="Typography.H3">Club Management</FluentLabel>
                    <FluentSpacer />
                    <FluentButton Appearance="Appearance.Accent">Manage club details, stadium information, and club branding.</FluentButton>
                </FluentStack>
            </FluentCard>
        </FluentGridItem>

        <FluentGridItem xs="12" sm="12" md="12" lg="4">
            <FluentCard Style="cursor: pointer; height: 100%;" @onclick="@(() => Navigation.NavigateTo(Routes.Admin.Players))">
                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Start">
                    <FluentIcon Value="@(new Icons.Regular.Size32.PeopleSettings())" Color="Color.Accent" />
                    <FluentLabel Weight="FontWeight.Bold" Typo="Typography.H3">Players Management</FluentLabel>
                    <FluentSpacer />
                    <FluentButton Appearance="Appearance.Accent">Manage players, positions, squad numbers, and player statistics.</FluentButton>
                </FluentStack>
            </FluentCard>
        </FluentGridItem>

        <FluentGridItem xs="12" sm="12" md="12" lg="4">
            <FluentCard Style="cursor: pointer; height: 100%;" @onclick="@(() => Navigation.NavigateTo(Routes.Admin.Fixtures))">
                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Start">
                    <FluentIcon Value="@(new Icons.Regular.Size32.CalendarSettings())" Color="Color.Accent" />
                    <FluentLabel Weight="FontWeight.Bold" Typo="Typography.H3">Fixtures Management</FluentLabel>
                    <FluentSpacer />
                    <FluentButton Appearance="Appearance.Accent">Manage fixtures, results, seasons, competitions, and match data.</FluentButton>
                </FluentStack>
            </FluentCard>
        </FluentGridItem>
    </FluentGrid>
</FluentStack>

<FluentCard Style="height: 100%;">
    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Stretch">

     <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size20.History())" Color="Color.Accent" />
            <FluentLabel Weight="FontWeight.Bold" Typo="Typography.H3">Recent Form</FluentLabel>
        </FluentStack>

        <FluentDivider />

        @if (Results is null || Results.Count == 0)
        {
            <FluentStack Orientation="Orientation.Vertical" VerticalAlignment="VerticalAlignment.Center" HorizontalAlignment="HorizontalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.QuestionCircle())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">No recent form</FluentLabel>
            </FluentStack>
        }
        else
        {
            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Style="width: 100%;">
                @foreach (var result in Results)
                {
                    <FluentBadge Appearance="Appearance.Neutral" Fill="@GetScoreBadgeFill(result.Result)">
                        <FluentLabel Weight="FontWeight.Bold" Typo="Typography.H4" Color="Color.Custom" CustomColor="white" Style="margin: 0.25rem 0.5rem;">
                            @result.HomeGoals - @result.AwayGoals
                        </FluentLabel>
                    </FluentBadge>
                }
            </FluentStack>
        }
    </FluentStack>
</FluentCard>

@code {
    [Parameter] public List<RecentFormItemDto>? Results { get; set; }

    private string GetScoreBadgeFill(string result) => result.ToLower();

}